<style>
/* ── Reset ──────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ── Tokens ─────────────────────────────────────────────── */
:root {
  --bg:       #f5f2eb;
  --surface:  #ffffff;
  --ink:      #1a1814;
  --muted:    #8a8679;
  --border:   #dedad2;
  --r1:       #c84b31;   /* room 1 accent */
  --r2:       #2a6496;   /* room 2 accent */
  --avail:    #3a7d44;
  --mine:     #2a6496;
  --taken:    #c84b31;
  --yellow:   #e8b84b;
  --radius:   14px;
  --shadow:   0 2px 16px rgba(26,24,20,.08);
}

/* ── Base ───────────────────────────────────────────────── */
body {
  background: var(--bg);
  color: var(--ink);
  font-family: 'Epilogue', sans-serif;
  min-height: 100vh;
  padding: 28px 16px 60px;
}

/* ── Header ─────────────────────────────────────────────── */
.header {
  max-width: 680px;
  margin: 0 auto 32px;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
  border-bottom: 2px solid var(--ink);
  padding-bottom: 20px;
}

.header-left h1 {
  font-family: 'Syne', sans-serif;
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 800;
  letter-spacing: -1px;
  line-height: 1;
}

.header-left p {
  color: var(--muted);
  font-size: 0.85rem;
  margin-top: 6px;
}

.user-chip {
  display: flex;
  align-items: center;
  gap: 10px;
  background: var(--ink);
  color: #fff;
  border-radius: 40px;
  padding: 8px 16px 8px 8px;
}

.user-chip .avatar {
  width: 30px; height: 30px;
  border-radius: 50%;
  background: var(--yellow);
  color: var(--ink);
  font-weight: 800;
  font-size: 0.85rem;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Syne', sans-serif;
}

.user-chip input {
  background: transparent;
  border: none;
  color: #fff;
  font-family: 'Epilogue', sans-serif;
  font-size: 0.88rem;
  outline: none;
  width: 140px;
}

.user-chip input::placeholder { color: rgba(255,255,255,.45); }

/* ── Date Nav ───────────────────────────────────────────── */
.date-row {
  max-width: 680px;
  margin: 0 auto 28px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.date-row .date-label {
  flex: 1;
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: clamp(0.95rem, 2vw, 1.15rem);
}

.date-row .today-tag {
  background: var(--yellow);
  color: var(--ink);
  font-size: 0.72rem;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 20px;
  text-transform: uppercase;
  letter-spacing: .04em;
}

.nav-btn {
  background: var(--surface);
  border: 1.5px solid var(--border);
  color: var(--ink);
  width: 38px; height: 38px;
  border-radius: 50%;
  cursor: pointer;
  font-size: 1.1rem;
  display: flex; align-items: center; justify-content: center;
  transition: all .15s;
  flex-shrink: 0;
}
.nav-btn:hover { background: var(--ink); color: #fff; border-color: var(--ink); }

.today-btn {
  background: transparent;
  border: 1.5px solid var(--border);
  color: var(--muted);
  font-family: 'Epilogue', sans-serif;
  font-size: 0.78rem;
  font-weight: 600;
  padding: 0 14px;
  height: 38px;
  border-radius: 40px;
  cursor: pointer;
  transition: all .15s;
  flex-shrink: 0;
}
.today-btn:hover { border-color: var(--ink); color: var(--ink); }

/* ── Status banner ──────────────────────────────────────── */
#statusBanner {
  max-width: 680px;
  margin: 0 auto 20px;
  padding: 10px 16px;
  border-radius: 10px;
  font-size: 0.82rem;
  font-weight: 500;
  display: none;
}
#statusBanner.info  { background: #e8f4fd; color: #2a6496; border: 1px solid #b8d9f0; display:block; }
#statusBanner.error { background: #fdf0ee; color: #c84b31; border: 1px solid #f0c4bc; display:block; }
#statusBanner.ok    { background: #eef6f0; color: #3a7d44; border: 1px solid #b8ddbf; display:block; }

/* ── Rooms Grid ─────────────────────────────────────────── */
.rooms-grid {
  max-width: 680px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
}

/* ── Room Card ──────────────────────────────────────────── */
.room-card {
  background: var(--surface);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
  border: 1.5px solid var(--border);
}

.room-card-header {
  padding: 18px 20px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.room-stripe {
  width: 6px;
  height: 38px;
  border-radius: 4px;
  flex-shrink: 0;
}

.room-card-header h2 {
  font-family: 'Syne', sans-serif;
  font-weight: 700;
  font-size: 1.05rem;
}

.room-card-header .cap {
  margin-left: auto;
  font-size: 0.75rem;
  color: var(--muted);
  background: var(--bg);
  padding: 4px 10px;
  border-radius: 20px;
  border: 1px solid var(--border);
}

/* ── Slots ──────────────────────────────────────────────── */
.slots-list {
  padding: 0 14px 14px;
  display: flex;
  flex-direction: column;
  gap: 5px;
  max-height: 600px;
  overflow-y: auto;
}

.slots-list::-webkit-scrollbar { width: 4px; }
.slots-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

.slot {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 11px;
  border-radius: 9px;
  border: 1.5px solid var(--border);
  transition: all .15s;
  background: var(--bg);
}

.slot.available { cursor: pointer; }
.slot.available:hover { border-color: var(--avail); background: #eef6f0; }

.slot.taken {
  background: #fdf0ee;
  border-color: #f0c4bc;
}

.slot.mine {
  background: #eef3fa;
  border-color: #b8d3f0;
  cursor: pointer;
}

.slot-indicator {
  width: 8px; height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.slot.available .slot-indicator { background: var(--avail); }
.slot.taken     .slot-indicator { background: var(--taken); }
.slot.mine      .slot-indicator { background: var(--mine); }

.slot-time {
  font-size: 0.78rem;
  font-weight: 600;
  min-width: 92px;
  color: var(--muted);
  font-variant-numeric: tabular-nums;
}

.slot-info { flex: 1; }
.slot-info .who    { font-size: 0.82rem; font-weight: 600; color: var(--ink); }
.slot-info .why    { font-size: 0.74rem; color: var(--muted); }
.slot-info .free   { font-size: 0.8rem; color: var(--avail); font-weight: 500; }

.slot-btn {
  font-size: 0.73rem;
  font-weight: 700;
  padding: 5px 12px;
  border-radius: 6px;
  border: none;
  cursor: pointer;
  font-family: 'Epilogue', sans-serif;
  transition: all .15s;
  flex-shrink: 0;
  text-transform: uppercase;
  letter-spacing: .04em;
}

.btn-book   { background: var(--ink); color: #fff; }
.btn-book:hover { background: #3a3830; }
.btn-cancel { background: transparent; color: var(--taken); border: 1.5px solid var(--taken) !important; }
.btn-cancel:hover { background: var(--taken); color: #fff; }

/* ── Modal ──────────────────────────────────────────────── */
.overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(26,24,20,.55);
  backdrop-filter: blur(3px);
  z-index: 200;
  align-items: center;
  justify-content: center;
  padding: 16px;
}
.overlay.open { display: flex; }

.modal {
  background: var(--surface);
  border-radius: 20px;
  padding: 30px;
  width: 100%; max-width: 420px;
  box-shadow: 0 24px 60px rgba(26,24,20,.18);
  animation: pop .22s cubic-bezier(.34,1.56,.64,1);
}

@keyframes pop {
  from { opacity:0; transform: scale(.93) translateY(12px); }
  to   { opacity:1; transform: scale(1) translateY(0); }
}

.modal-room-tag {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  padding: 3px 10px;
  border-radius: 20px;
  margin-bottom: 10px;
}

.modal h3 {
  font-family: 'Syne', sans-serif;
  font-weight: 800;
  font-size: 1.35rem;
  margin-bottom: 4px;
}

.modal .slot-detail {
  font-size: 0.82rem;
  color: var(--muted);
  margin-bottom: 24px;
}

.form-group { margin-bottom: 16px; }

.form-group label {
  display: block;
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--muted);
  margin-bottom: 7px;
}

.form-group input {
  width: 100%;
  background: var(--bg);
  border: 1.5px solid var(--border);
  color: var(--ink);
  padding: 11px 14px;
  border-radius: 10px;
  font-size: 0.9rem;
  font-family: 'Epilogue', sans-serif;
  outline: none;
  transition: border-color .2s;
}
.form-group input:focus { border-color: var(--ink); }

.modal-actions { display: flex; gap: 10px; margin-top: 22px; }

.btn-confirm {
  flex: 1;
  background: var(--ink);
  color: #fff;
  border: none;
  padding: 13px;
  border-radius: 10px;
  font-weight: 700;
  font-size: 0.88rem;
  cursor: pointer;
  font-family: 'Syne', sans-serif;
  transition: background .15s;
}
.btn-confirm:hover { background: #3a3830; }

.btn-dismiss {
  flex: 1;
  background: transparent;
  color: var(--muted);
  border: 1.5px solid var(--border);
  padding: 13px;
  border-radius: 10px;
  font-weight: 500;
  font-size: 0.88rem;
  cursor: pointer;
  font-family: 'Epilogue', sans-serif;
  transition: all .15s;
}
.btn-dismiss:hover { border-color: var(--ink); color: var(--ink); }

/* ── Legend ─────────────────────────────────────────────── */
.legend {
  max-width: 680px;
  margin: 28px auto 0;
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  font-size: 0.78rem;
  color: var(--muted);
}
.legend-item { display: flex; align-items: center; gap: 6px; }
.legend-dot  { width: 8px; height: 8px; border-radius: 50%; }

/* ── Setup Notice ───────────────────────────────────────── */
#setupNotice {
  max-width: 680px;
  margin: 0 auto 24px;
  background: #fffbea;
  border: 1.5px solid #f5d76e;
  border-radius: 12px;
  padding: 16px 20px;
  font-size: 0.85rem;
  line-height: 1.7;
}
#setupNotice strong { font-family: 'Syne', sans-serif; display:block; margin-bottom:4px; font-size:0.95rem; }
#setupNotice code {
  background: rgba(0,0,0,.07);
  padding: 1px 6px;
  border-radius: 4px;
  font-size: 0.82rem;
}
</style>
