<body>

<!-- Firebase configured for SankenOverseas -->

<!-- Header -->
<div class="header">
  <div class="header-left">
    <h1>SankenOverseas</h1>
    <p>Boardroom Booking · Pvt Ltd</p>
  </div>
  <div class="user-chip">
    <div class="avatar" id="avatarLetter">?</div>
    <input type="text" id="userNameInput" placeholder="Your name…" maxlength="30" autocomplete="off">
  </div>
</div>

<!-- Status -->
<div id="statusBanner"></div>

<!-- Date navigation -->
<div class="date-row">
  <button class="nav-btn" onclick="changeDay(-1)">‹</button>
  <div style="flex:1">
    <div class="date-label" id="dateLabel"></div>
  </div>
  <button class="nav-btn" onclick="changeDay(1)">›</button>
  <button class="today-btn" onclick="goToday()">Today</button>
</div>

<!-- Rooms -->
<div class="rooms-grid" id="roomsGrid"></div>

<!-- Legend -->
<div class="legend">
  <div class="legend-item"><div class="legend-dot" style="background:var(--avail)"></div> Available</div>
  <div class="legend-item"><div class="legend-dot" style="background:var(--taken)"></div> Booked by others</div>
  <div class="legend-item"><div class="legend-dot" style="background:var(--mine)"></div> Your booking</div>
</div>

<!-- Modal -->
<div class="overlay" id="overlay">
  <div class="modal">
    <div class="modal-room-tag" id="modalRoomTag"></div>
    <h3 id="modalTitle">Book Slot</h3>
    <div class="slot-detail" id="modalDetail"></div>
    <div class="form-group">
      <label>Your Name</label>
      <input type="text" id="mName" placeholder="e.g. Kasun Perera" maxlength="30">
    </div>
    <div class="form-group">
      <label>Meeting Purpose</label>
      <input type="text" id="mPurpose" placeholder="e.g. Weekly sync, Client call…" maxlength="60">
    </div>
    <div class="modal-actions">
      <button class="btn-dismiss" onclick="closeModal()">Cancel</button>
      <button class="btn-confirm" onclick="confirmBooking()">🔒 Confirm Booking</button>
    </div>
  </div>
</div>

<script>
// ─────────────────────────────────────────────
// Config
// ─────────────────────────────────────────────
const ROOMS = [
  { id: 'room1', name: 'Boardroom', capacity: '8 people', color: '#c84b31' }
];

// Half-hour slots 08:00 → 18:00
const SLOTS = [];
for (let h = 8; h < 18; h++) {
  SLOTS.push(`${String(h).padStart(2,'0')}:00`);
  SLOTS.push(`${String(h).padStart(2,'0')}:30`);
}

// ─────────────────────────────────────────────
// State
// ─────────────────────────────────────────────
let currentDate = today();
let userName    = '';
let bookings    = {};   // key → { name, purpose, bookedAt }
let pendingSlot = null;
let firebaseReady = false;
let dbListeners   = {};

// ─────────────────────────────────────────────
// Helpers
// ─────────────────────────────────────────────
function today() {
  const d = new Date(); d.setHours(0,0,0,0); return d;
}

function dateKey(d) {
  return d.toISOString().slice(0,10);
}

function slotKey(roomId, time) {
  return `${roomId}__${dateKey(currentDate)}__${time.replace(':','h')}`;
}

function formatDate(d) {
  return d.toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
}

function isToday(d) {
  return d.getTime() === today().getTime();
}

function nextTime(t) {
  const [h,m] = t.split(':').map(Number);
  const total = h*60 + m + 30;
  return `${String(Math.floor(total/60)).padStart(2,'0')}:${String(total%60).padStart(2,'0')}`;
}

// ─────────────────────────────────────────────
// Local storage fallback
// ─────────────────────────────────────────────
function localGet()    { try { return JSON.parse(localStorage.getItem('mbookings')||'{}'); } catch { return {}; } }
function localSet(b)   { localStorage.setItem('mbookings', JSON.stringify(b)); }

// ─────────────────────────────────────────────
// Firebase integration
// ─────────────────────────────────────────────
window.addEventListener('firebase-ready', () => {
  const cfg = document.querySelector('script[type="module"]').textContent;
  if (cfg.includes('YOUR_API_KEY')) {
    showStatus('Firebase not configured yet — running in single-device demo mode.', 'info');
    bookings = localGet();
    render();
    return;
  }
  firebaseReady = true;
  document.getElementById('setupNotice').style.display = 'none';
  showStatus('Connected — bookings sync in real time ✓', 'ok');
  setTimeout(() => hideStatus(), 3000);
  subscribeToDate();
});

function subscribeToDate() {
  if (!firebaseReady) return;
  const { db, ref, onValue } = window._fb;
  const path = `bookings/${dateKey(currentDate)}`;
  // Unsubscribe previous
  if (dbListeners[path]) dbListeners[path]();
  const r = ref(db, path);
  const unsub = onValue(r, snap => {
    bookings = snap.val() || {};
    render();
  });
  dbListeners[path] = unsub;
}

async function fbSet(key, data) {
  if (!firebaseReady) { const b=localGet(); b[key]=data; localSet(b); bookings=localGet(); render(); return; }
  const { db, ref, set } = window._fb;
  const [roomId, date, time] = key.split('__');
  await set(ref(db, `bookings/${date}/${key}`), data);
}

async function fbRemove(key) {
  if (!firebaseReady) { const b=localGet(); delete b[key]; localSet(b); bookings=localGet(); render(); return; }
  const { db, ref, remove } = window._fb;
  const [roomId, date, time] = key.split('__');
  await remove(ref(db, `bookings/${date}/${key}`));
}

// ─────────────────────────────────────────────
// Render
// ─────────────────────────────────────────────
function render() {
  // Date label
  document.getElementById('dateLabel').innerHTML =
    `${formatDate(currentDate)}${isToday(currentDate) ? ' <span class="today-tag">Today</span>' : ''}`;

  const grid = document.getElementById('roomsGrid');
  grid.innerHTML = '';

  ROOMS.forEach(room => {
    const card = document.createElement('div');
    card.className = 'room-card';
    card.innerHTML = `
      <div class="room-card-header">
        <div class="room-stripe" style="background:${room.color}"></div>
        <h2>${room.name}</h2>
        <span class="cap">👥 ${room.capacity}</span>
      </div>
      <div class="slots-list" id="sl_${room.id}"></div>
    `;
    grid.appendChild(card);

    const list = card.querySelector(`#sl_${room.id}`);
    SLOTS.forEach(time => {
      const key  = slotKey(room.id, time);
      const end  = nextTime(time);
      const bk   = bookings[key];
      const mine = bk && bk.name === userName && userName.trim() !== '';
      const cls  = bk ? (mine ? 'mine' : 'taken') : 'available';

      const slot = document.createElement('div');
      slot.className = `slot ${cls}`;

      let infoHTML = '';
      let btnHTML  = '';

      if (bk) {
        infoHTML = `<div class="slot-info"><div class="who">${esc(bk.name)}</div><div class="why">${esc(bk.purpose)}</div></div>`;
        if (mine) btnHTML = `<button class="slot-btn btn-cancel" onclick="cancelSlot('${key}')">Cancel</button>`;
      } else {
        infoHTML = `<div class="slot-info"><span class="free">Available</span></div>`;
        btnHTML  = `<button class="slot-btn btn-book" onclick="openModal('${room.id}','${esc(room.name)}','${time}','${end}','${room.color}')">Book</button>`;
      }

      slot.innerHTML = `
        <div class="slot-indicator"></div>
        <div class="slot-time">${time} – ${end}</div>
        ${infoHTML}
        ${btnHTML}
      `;
      list.appendChild(slot);
    });
  });
}

function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

// ─────────────────────────────────────────────
// Date navigation
// ─────────────────────────────────────────────
function changeDay(n) {
  currentDate = new Date(currentDate);
  currentDate.setDate(currentDate.getDate() + n);
  subscribeToDate();
  if (!firebaseReady) render();
}

function goToday() {
  currentDate = today();
  subscribeToDate();
  if (!firebaseReady) render();
}

// ─────────────────────────────────────────────
// Booking modal
// ─────────────────────────────────────────────
function openModal(roomId, roomName, time, end, color) {
  if (!userName.trim()) {
    showStatus('Please enter your name at the top first.', 'error');
    document.getElementById('userNameInput').focus();
    return;
  }
  pendingSlot = { roomId, time };
  const tag = document.getElementById('modalRoomTag');
  tag.textContent = roomName;
  tag.style.background = color + '22';
  tag.style.color       = color;
  document.getElementById('modalTitle').textContent   = `${time} – ${end}`;
  document.getElementById('modalDetail').textContent  = formatDate(currentDate);
  document.getElementById('mName').value    = userName;
  document.getElementById('mPurpose').value = '';
  document.getElementById('overlay').classList.add('open');
  setTimeout(() => document.getElementById('mPurpose').focus(), 120);
}

function closeModal() {
  document.getElementById('overlay').classList.remove('open');
  pendingSlot = null;
}

async function confirmBooking() {
  const name    = document.getElementById('mName').value.trim();
  const purpose = document.getElementById('mPurpose').value.trim();
  if (!name)    { showStatus('Please enter your name.', 'error'); return; }
  if (!purpose) { showStatus('Please describe the meeting purpose.', 'error'); return; }

  const key = slotKey(pendingSlot.roomId, pendingSlot.time);
  if (bookings[key]) { showStatus('Slot just got taken — please choose another.', 'error'); closeModal(); return; }

  userName = name;
  updateAvatar();

  await fbSet(key, { name, purpose, bookedAt: Date.now() });
  closeModal();
  showStatus('Room booked successfully! 🎉', 'ok');
  setTimeout(() => hideStatus(), 3000);
}

async function cancelSlot(key) {
  if (!confirm('Cancel your booking for this slot?')) return;
  await fbRemove(key);
  showStatus('Booking cancelled.', 'info');
  setTimeout(() => hideStatus(), 2500);
}

// ─────────────────────────────────────────────
// Name input
// ─────────────────────────────────────────────
document.getElementById('userNameInput').addEventListener('input', function() {
  userName = this.value.trim();
  updateAvatar();
  render();
});

function updateAvatar() {
  const el = document.getElementById('avatarLetter');
  el.textContent = userName ? userName[0].toUpperCase() : '?';
}

// ─────────────────────────────────────────────
// Status banner
// ─────────────────────────────────────────────
function showStatus(msg, type) {
  const el = document.getElementById('statusBanner');
  el.textContent = msg;
  el.className = type;
}
function hideStatus() {
  const el = document.getElementById('statusBanner');
  el.className = '';
  el.style.display = 'none';
  el.textContent = '';
}

// ─────────────────────────────────────────────
// Close modal on overlay click
// ─────────────────────────────────────────────
document.getElementById('overlay').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});

// ─────────────────────────────────────────────
// Init (fallback if Firebase module doesn't fire)
// ─────────────────────────────────────────────
setTimeout(() => {
  if (!firebaseReady) {
    bookings = localGet();
    render();
  }
}, 800);

// Initial render
render();
</script>
</body>
</html>
